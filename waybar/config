{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,

    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "idle_inhibitor",
        "network",
        "bluetooth",
        "pulseaudio",
        "tray",
        "custom/power"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "persistent-workspaces": {
            "1:≤░Με": [],
            "2:ΌηΧ": [],
            "3:ΌζΖ": [],
            "4:≤░Τ▒": [],
            "5:≤░Χπ": []
        }
    },

    "sway/mode": {
        "format": "{}",
        "tooltip": false
    },

    "clock": {
        "format": "≤░Δ░  {:%H:%M}",
        "tooltip-format": "<big>{:%A %d %B %Y}</big>\n<tt>{calendar}</tt>",
        "format-alt": "≤░Δ░  {:%a %d %b}"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "≤░δΛ",
            "deactivated": "≤░╛ς"
        },
        "tooltip-format": "Idle Inhibitor",
        "tooltip-format-activated": "Screen will not sleep"
    },

    "network": {
        "format-wifi": "≤░νρ ",
        "format-ethernet": "Ό╜Ε ",
        "format-disconnected": "≤░νφ ",
        "tooltip-format-wifi": "≤░νρ {essid}\nSignal: {signalStrength}%\nIP: {ipaddr}",
        "tooltip-format-disconnected": "WiFi Disconnected",
        "on-click": "gtk-launch impala"
    },

    "bluetooth": {
        "format": "ΎΛΦ",
        "format-disabled": "≤░Γ▓",
        "format-connected": "≤░ξι ",
        "tooltip-format": "Bluetooth",
        "tooltip-format-connected": "≤░ξι {device_alias}",
        "on-click": "gtk-launch bluetuith"
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "Ό╗ρ ",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ ", "ΎΑρ "],
            "headphone": "ΎΑξ ",
            "hands-free": "≤░ΨΒ ",
            "portable": "≤░ΧΥ"
        },
        "format-source": "{volume}%",
        "format-source-muted": "≤░ζθ ",
        "tooltip-format": "Output: {volume}%\nInput: {format_source}",
        "tooltip-format-muted": "Output: Muted\nInput: {format_source}",
        "on-click": "gtk-launch pulsemixer",
        "on-scroll-up": "pulsemixer --volume +5",
        "on-scroll-down": "pulsemixer --volume -5"
    },

    "tray": {
        "icon-size": 14,
        "spacing": 10
    },

    "custom/power": {
        "format": "≤░Ρξ",
        "tooltip": false,
        "on-click": "~/.config/sway/scripts/power-menu.sh"
    }
}
